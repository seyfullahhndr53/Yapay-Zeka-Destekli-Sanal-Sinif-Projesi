# =====================================
# 🔧 Backend (.env) Example
# =====================================
# Copy this file to `.env` and adjust values.
# For easy local dev, you can also run: `./run_simple.ps1`

# ==================== Server ====================
HOST=127.0.0.1
PORT=5001
DEBUG=true

# Disable SSL inside Flask (recommended for local dev and when running behind Nginx/Cloudflare)
DISABLE_SSL=1

# ==================== Model ====================
MODEL_PATH=./Duygu_Tanima.h5

# ==================== Security & Limits ====================
MAX_IMAGE_SIZE=5242880
MAX_STUDENTS=200
RATE_LIMIT=60
SESSION_TIMEOUT=3600

# API Keys (Optional but recommended for security)
# Defaults in extensions: student_secret_key_2025, teacher_admin_key_2025
API_KEY=student_secret_key_2025
TEACHER_API_KEY=teacher_admin_key_2025

# CORS Origins (Comma separated list of allowed origins)
# Use "chrome-extension://*" to allow all extensions or specify ID
CORS_ORIGINS=https://meet.google.com,https://*.zoom.us,https://*.bigbluebutton.org,chrome-extension://*
RATE_LIMIT=60
SESSION_TIMEOUT=3600

# ==================== CORS ====================
# Comma-separated allowed origins (extensions + supported meeting platforms)
CORS_ORIGINS=chrome-extension://*,https://meet.google.com,https://*.zoom.us,https://*.zoom.com,https://*.bigbluebutton.org,http://127.0.0.1:*,http://localhost:*,https://localhost:*,https://127.0.0.1:*

# ==================== API Keys ====================
# Student extension uses API_KEY
API_KEY=student_secret_key_2025

# Teacher extension uses TEACHER_API_KEY (falls back to API_KEY if empty)
TEACHER_API_KEY=teacher_admin_key_2025
